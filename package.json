{
  "name": "apsrt",
  "description": "Automated Property-based Snapshot Regression Testing",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .apsrt dist blablabla script src/__snapshots__",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.fixtures.json && tsc --noEmit -p tsconfig.nondeterministic-fixtures.json && tsc --noEmit -p tsconfig.multiple-nondeterministic-fixtures.json && tsc --noEmit -p tsconfig.module-loading-fixtures.json"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "tsdown": "^0.12.9",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "fast-check": "^4.1.1",
    "ts-morph": "^25.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vite-node": "^3.2.4",
    "vitest": "^3.2.4"
  },
  "exports": {
    "./cli": "./dist/cli.js",
    "./runtime.test": "./dist/runtime.test.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "apsrt": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  }
}
