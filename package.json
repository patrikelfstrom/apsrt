{
  "name": "@patrikelfstrom/apsrt",
  "description": "Automated Property-based Snapshot Regression Testing",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.fixtures.json && tsc --noEmit -p tsconfig.nondeterministic-fixtures.json && tsc --noEmit -p tsconfig.multiple-nondeterministic-fixtures.json && tsc --noEmit -p tsconfig.module-loading-fixtures.json"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "fast-check": "^4.6.0",
    "ts-morph": "^27.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.2"
  },
  "exports": {
    "./cli": "./dist/cli.mjs",
    "./runtime.test": "./dist/runtime.test.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "apsrt": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "volta": {
    "node": "24.14.1"
  }
}
